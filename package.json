{
  "name": "billy-agent",
  "version": "1.0.6",
  "description": "Simple AI for your projects - generate, modify, validate, analyze, extract, and execute with natural language prompts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "billy-agent": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "node --test",
    "lint": "biome check src/",
    "lint:fix": "biome check --apply src/",
    "format": "biome format --write src/",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "ai",
    "llm",
    "openai",
    "groq",
    "agent",
    "generative",
    "codegen"
  ],
  "author": {
    "name": "Plinio",
    "url": "https://github.com/plinio8899"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plinio8899/billy-agent.git"
  },
  "bugs": {
    "url": "https://github.com/plinio8899/billy-agent/issues"
  },
  "homepage": "https://github.com/plinio8899/billy-agent#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "groq-sdk": "^0.8.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitepress": "^1.6.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
